#!/usr/bin/env bash
# Pre-push hook: warn before pushing to main.
#
# Install via the kit's installer (recommended — uses a symlink so updates flow through):
#   ~/Claude_Upgrade/install.sh --project /path/to/your/project
#
# In non-interactive or CI environments (no /dev/tty available), this hook
# allows the push through without prompting. The prompt is a safety net for
# humans, not an authorization barrier — CI is expected to enforce its own rules.

protected_branch="main"
remote="$1"

while read local_ref local_sha remote_ref remote_sha; do
    # Extract branch name from refs/heads/<branch>
    remote_branch="${remote_ref##refs/heads/}"

    if [ "$remote_branch" = "$protected_branch" ]; then
        # Non-interactive detection: try to open /dev/tty. On macOS, the device
        # node exists (so -r passes) but cannot be opened when there's no
        # controlling terminal — so the open is the authoritative test.
        if [ ! -r /dev/tty ] || ! exec < /dev/tty 2>/dev/null; then
            exit 0
        fi
        echo ""
        echo "⚠️  You are about to push to '$protected_branch' on '$remote'."
        printf "Are you sure? (y/n) "
        read -r answer
        case "$answer" in
            y|Y|yes|YES)
                echo "Proceeding with push to $protected_branch."
                ;;
            *)
                echo "Push to $protected_branch aborted."
                exit 1
                ;;
        esac
    fi
done

exit 0
